  },
  "dependencies": {
    "@orpc/server": "catalog:",
    "@tepirek-revamped/auth": "workspace:*",
    "@tepirek-revamped/config": "workspace:*",
    "@tepirek-revamped/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "evlog": "^2.19.1",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
