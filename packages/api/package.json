{
  "name": "@tepirek-revamped/api",
  "type": "module",
  "exports": {
    "./adapters/*": {
      "browser": null,
      "default": "./src/adapters/*.ts"
    },
    "./domain/squad-builder/*": {
      "default": "./src/domain/squad-builder/*.ts"
    },
    "./observability": {
      "browser": null,
      "default": "./src/observability.ts"
    },
    "./protocol/*": {
      "default": "./src/protocol/*.ts"
    },
    "./server/*": {
      "browser": null,
      "default": "./src/server/*.ts"
    },
    "./services/*": {
      "browser": null,
      "default": "./src/services/*.ts"
    }
  },
  "scripts": {
    "check-boundary": "node scripts/check-package-boundary.mjs",
    "check-types": "tsc --noEmit --composite false --declaration false --declarationMap false --rootDir src",
    "test": "pnpm check-boundary && vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@tepirek-revamped/auth": "workspace:*",
    "@tepirek-revamped/config": "workspace:*",
    "@tepirek-revamped/db": "workspace:*",
    "drizzle-orm": "catalog:",
    "effect": "catalog:",
    "firecrawl": "^4.28.3",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "@types/pg": "^8.20.0",
    "pg": "^8.22.0",
    "typescript": "catalog:"
  }
}
