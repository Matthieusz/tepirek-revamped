{
  "name": "tepirek-revamped",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "test": "turbo test",
    "test:integration": "turbo -F @tepirek-revamped/api test:integration",
    "test:smoke": "turbo test:smoke",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @tepirek-revamped/db db:push",
    "db:studio": "turbo -F @tepirek-revamped/db db:studio",
    "db:generate": "turbo -F @tepirek-revamped/db db:generate",
    "db:migrate": "turbo -F @tepirek-revamped/db db:migrate",
    "db:start": "turbo -F @tepirek-revamped/db db:start",
    "db:watch": "turbo -F @tepirek-revamped/db db:watch",
    "db:stop": "turbo -F @tepirek-revamped/db db:stop",
    "db:down": "turbo -F @tepirek-revamped/db db:down",
    "check": "ultracite check",
    "check:unused": "knip",
    "fix": "ultracite fix",
    "prepare": "effect-language-service patch"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@tepirek-revamped/config": "workspace:*",
    "@types/bun": "^1.3.14",
    "effect": "catalog:",
    "knip": "^5.88.1",
    "lefthook": "latest",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-tsgolint": "^0.23.0",
    "turbo": "^2.10.0",
    "typescript": "catalog:",
    "ultracite": "7.8.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
