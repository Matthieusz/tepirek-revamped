# Example environment variables. Values are placeholders only.
#
# Copy this file to `.env` and fill in real values. `.env` is git-ignored and
# must never be committed. If a real secret is exposed (terminal transcript,
# screenshot, issue, chat, agent output), rotate it immediately in the
# relevant provider dashboard. Use deployment secret stores for production.

# Database
DATABASE_URL=
TEST_DATABASE_URL=

# Auth
# Startup validation requires at least 32 characters.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=
CORS_ORIGIN=

# Discord OAuth, required by current auth configuration.
# Client credentials and the server ID must be non-empty.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SERVER_ID=

# Squad builder / Firecrawl (the API key is required by startup configuration).
# The API key must be non-empty.
FIRECRAWL_API_KEY=
FIRECRAWL_MONTHLY_REQUEST_BUDGET=900

# OpenTelemetry (optional; malformed configured values block startup)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_RESOURCE_ATTRIBUTES=
OTEL_DEPLOYMENT_ENVIRONMENT_NAME=
TEPIREK_LOG_LEVEL=INFO
TEPIREK_PRINT_LOGS=0